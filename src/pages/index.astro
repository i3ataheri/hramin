---
import '../styles/language.scss';
import Layout from '../layouts/App.astro';
---

<Layout>
  <!-- Loading Overlay -->
  <div class="loading-overlay" id="loading-overlay">
    <div class="loader"></div>
    <div class="loading-text">Loading...</div>
  </div>

  <!-- Language Selection Page -->
  <div class="language-page" id="language-page">
    <!-- Animated Background -->
    <div class="lang-bg"></div>

    <!-- Geometric Pattern -->
    <div class="geometric-pattern">
      <div class="pattern-ring"></div>
      <div class="pattern-ring"></div>
      <div class="pattern-ring"></div>
    </div>

    <!-- Floating Particles -->
    <div class="particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <!-- Main Content -->
    <div class="lang-content">
      <!-- Language Grid -->
      <div class="lang-grid" id="lang-grid"></div>


    </div>
  </div>

  <script is:inline>
    // ═══════ LANGUAGE DATA ═══════
    const allLangs = [
      { code: 'ar', label: 'AR', dir: 'rtl', font: 'Vazirmatn', native: 'العربية', flag: '/flags/sa.svg' },
      { code: 'fa', label: 'FA', dir: 'rtl', font: 'Vazirmatn', native: 'فارسی', flag: '/flags/ir.svg' },
      { code: 'en', label: 'EN', dir: 'ltr', font: 'Inter', native: 'English', flag: '/flags/gb.svg' },
      { code: 'ur', label: 'UR', dir: 'rtl', font: 'Gulzar', native: 'اردو', flag: '/flags/pk.svg' },
      { code: 'id', label: 'ID', dir: 'ltr', font: 'Inter', native: 'Indonesia', flag: '/flags/id.svg' },
      { code: 'bn', label: 'BN', dir: 'ltr', font: 'Noto Sans Bengali', native: 'বাংলা', flag: '/flags/bd.svg' },
      { code: 'tr', label: 'TR', dir: 'ltr', font: 'Inter', native: 'Türkçe', flag: '/flags/tr.svg' },
      { code: 'ms', label: 'MS', dir: 'ltr', font: 'Inter', native: 'Melayu', flag: '/flags/my.svg' },
      { code: 'fr', label: 'FR', dir: 'ltr', font: 'Inter', native: 'Français', flag: '/flags/fr.svg' },
      { code: 'sw', label: 'SW', dir: 'ltr', font: 'Inter', native: 'Kiswahili', flag: '/flags/tz.svg' },
      { code: 'ha', label: 'HA', dir: 'ltr', font: 'Inter', native: 'Hausa', flag: '/flags/ng.svg' },
      { code: 'ps', label: 'PS', dir: 'rtl', font: 'Vazirmatn', native: 'پښتو', flag: '/flags/af.svg' },
      { code: 'uz', label: 'UZ', dir: 'ltr', font: 'Inter', native: "O'zbek", flag: '/flags/uz.svg' },
      { code: 'ru', label: 'RU', dir: 'ltr', font: 'Inter', native: 'Русский', flag: '/flags/ru.svg' },
      { code: 'zh', label: 'ZH', dir: 'ltr', font: 'Noto Sans SC', native: '中文', flag: '/flags/cn.svg' },
      { code: 'az', label: 'AZ', dir: 'ltr', font: 'Inter', native: 'Azərbaycan', flag: '/flags/az.svg' },
      { code: 'ku', label: 'KU', dir: 'ltr', font: 'Inter', native: 'Kurdî', flag: '/flags/ku.svg' },
      { code: 'so', label: 'SO', dir: 'ltr', font: 'Inter', native: 'Soomaali', flag: '/flags/so.svg' },
      { code: 'bs', label: 'BS', dir: 'ltr', font: 'Inter', native: 'Bosanski', flag: '/flags/ba.svg' },
      { code: 'tg', label: 'TG', dir: 'ltr', font: 'Inter', native: 'Тоҷикӣ', flag: '/flags/tj.svg' }
    ];

    // ═══════ CHECK IF LANGUAGE ALREADY SELECTED ═══════
    const savedLang = localStorage.getItem('haramain_lang');
    if (savedLang) {
      window.location.href = '/welcome';
    }

    // ═══════ RENDER LANGUAGE GRID ═══════
    function renderLangGrid() {
      const grid = document.getElementById('lang-grid');
      if (!grid) return;

      grid.innerHTML = allLangs.map(lang => {
        let iconClass = 'lang-card__icon';

        return `
          <div class="lang-card" data-lang="${lang.code}" data-dir="${lang.dir}">
            <div class="ripple-container"></div>
            <img class="${iconClass}" src="${lang.flag}" alt="${lang.native}" loading="lazy">
            <div class="lang-card__name" style="font-family: '${lang.font}', sans-serif !important">${lang.native}</div>
            <div class="lang-card__code">${lang.label}</div>
          </div>
        `;
      }).join('');

      // Add click listeners
      grid.querySelectorAll('.lang-card').forEach(card => {
        card.addEventListener('click', () => selectLanguage(card));
      });
    }

    // ═══════ SELECT LANGUAGE ═══════
    function selectLanguage(card) {
      const langCode = card.dataset.lang;
      const langDir = card.dataset.dir;

      // Remove previous selection
      document.querySelectorAll('.lang-card').forEach(c => c.classList.remove('selected'));

      // Add selection with ripple
      card.classList.add('selected');
      createRipple(card);

      // Save to localStorage
      localStorage.setItem('haramain_lang', langCode);
      localStorage.setItem('haramain_dir', langDir);

      // Transition to welcome page
      setTimeout(() => {
        const page = document.getElementById('language-page');
        page.classList.add('exiting');
        
        setTimeout(() => {
          window.location.href = '/welcome';
        }, 800);
      }, 600);
    }

    // ═══════ RIPPLE EFFECT ═══════
    function createRipple(card) {
      const container = card.querySelector('.ripple-container');
      if (!container) return;

      const ripple = document.createElement('div');
      ripple.className = 'ripple';
      ripple.style.left = '50%';
      ripple.style.top = '50%';
      ripple.style.transform = 'translate(-50%, -50%)';
      container.appendChild(ripple);

      setTimeout(() => ripple.remove(), 800);
    }

    // ═══════ HIDE LOADING ═══════
    window.addEventListener('load', () => {
      renderLangGrid();
      
      setTimeout(() => {
        const loading = document.getElementById('loading-overlay');
        if (loading) loading.classList.add('hidden');
      }, 500);
    });
  </script>
</Layout>
