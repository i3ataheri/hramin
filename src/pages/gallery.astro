---
import Layout from '../layouts/App.astro';
import '../styles/gallery.scss';
import '../styles/place-menu.scss';
---

<Layout>
  <div class="gallery" id="gallery">
    <!-- Progress bars -->
    <div class="progress-bar" id="progress-bar"></div>

    <!-- Top bar -->
    <div class="gallery-top">
      <div class="top-left-btns">
        <button class="change-lang-btn" id="change-lang-btn" title="تغییر زبان">
          <svg viewBox="0 0 24 24" width="22" height="22">
            <path d="M12.87 15.07l-2.54-2.51.03-.03c1.74-1.94 2.98-4.17 3.71-6.53H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z" fill="currentColor"/>
          </svg>
        </button>
        <button class="shop-btn" id="shop-btn" title="فروشگاه">
          <svg viewBox="0 0 24 24" width="20" height="20">
            <path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM7.16 14.26l.04-.12.94-1.7h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 20.04 4H5.21l-.94-2H1v2h2l3.6 7.59-1.35 2.44C4.52 15.37 5.48 17 7 17h12v-2H7.42c-.13 0-.25-.11-.26-.24z" fill="currentColor"/>
          </svg>
        </button>
      </div>
      <div class="city-switcher">
        <button class="city-tab active" data-city="makkah" id="btn-makkah">مكة المكرمة</button>
        <button class="city-tab" data-city="madinah" id="btn-madinah">المدينة المنورة</button>
      </div>
      <div class="top-right-btns">
        <button class="pause-btn" id="pause-btn" aria-label="pause">
          <svg class="icon-pause" viewBox="0 0 24 24" width="20" height="20">
            <rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"/>
            <rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"/>
          </svg>
          <svg class="icon-play" viewBox="0 0 24 24" width="20" height="20" style="display:none">
            <path d="M8 5v14l11-7z" fill="currentColor"/>
          </svg>
        </button>
        <button class="info-btn" id="info-btn" aria-label="info">
          <img src="/icons/info.svg" alt="" width="24" height="24">
        </button>
      </div>
    </div>

    <!-- Stories viewport -->
    <div class="stories-viewport" id="stories-viewport">
      <!-- Rendered by JS -->
    </div>

    <!-- Story info -->
    <div class="story-info" id="story-info">
      <h2 class="story-title" id="story-title"></h2>
      <p class="story-short" id="story-short"></p>
    </div>

    <!-- Place menu -->
    <div class="place-menu" id="place-menu">
      <!-- Rendered by JS -->
    </div>

    <!-- Description overlay -->
    <div class="desc-panel" id="desc-panel">
      <div class="desc-handle"></div>
      <div class="desc-content">
        <h2 class="desc-title" id="modal-title"></h2>
        <div class="desc-text" id="modal-description"></div>
      </div>
      <button class="close-btn" id="close-desc">
        <svg viewBox="0 0 24 24" width="22" height="22">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

  </div>
</Layout>
